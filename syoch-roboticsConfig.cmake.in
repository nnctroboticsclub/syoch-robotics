@PACKAGE_INIT@

find_package(ikarashiCAN_mk2 REQUIRED)
find_package(ikakoMDC REQUIRED)
find_package(IkakoRobomas REQUIRED)
find_package(MotorController REQUIRED)
find_package(Nano REQUIRED)

# プロジェクト直下の CMakeLists.txt の configure_package_config_file で作成したファイルを指定する
include("${CMAKE_CURRENT_LIST_DIR}/sroboTargets.cmake")

check_required_components(syoch-robotics)
